##############################################################
# GMCC Hospital Token System — Backend Environment Template
# Copy this file to .env and fill in your values.
# Command: cp .env.example .env && php artisan key:generate
##############################################################

# ── Application ────────────────────────────────────────────
APP_NAME="GMCC Hospital Token System"
APP_ENV=local                         # local | staging | production
APP_KEY=                              # Auto-generated: php artisan key:generate
APP_DEBUG=true                        # Set to false in production
APP_URL=http://localhost              # Your backend URL (e.g. https://api.gmcch.in)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ── Security ───────────────────────────────────────────────
BCRYPT_ROUNDS=12                      # Increase to 13-14 in production

# ── Database ───────────────────────────────────────────────
# SQLite (development only — no extra setup required)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# MySQL / MariaDB (recommended for production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=gmcch_hospital_db
# DB_USERNAME=root
# DB_PASSWORD=your_db_password_here

# ── Session ────────────────────────────────────────────────
SESSION_DRIVER=database               # file | database | redis
SESSION_LIFETIME=120                  # Minutes until session expires
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache ──────────────────────────────────────────────────
CACHE_STORE=file                      # file | redis | database

# ── Queue ──────────────────────────────────────────────────
QUEUE_CONNECTION=database             # sync | database | redis
# Run queue worker: php artisan queue:work

# ── File Storage ───────────────────────────────────────────
FILESYSTEM_DISK=public                # public (local) | s3
# After changing to public, run: php artisan storage:link

# AWS S3 (only needed if FILESYSTEM_DISK=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-south-1
# AWS_BUCKET=gmcch-hospital-assets
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Broadcasting ───────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── Logging ────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug                       # debug | info | warning | error (use error in production)

# ── Mail ───────────────────────────────────────────────────
MAIL_MAILER=log                       # log | smtp | mailgun | ses
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@gmcch.in"
MAIL_FROM_NAME="${APP_NAME}"

# ── Redis (optional - for cache/queue/sessions at scale) ───
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ── Frontend (Vite) ────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://127.0.0.1:8000/api

##############################################################
# FIRST-RUN CHECKLIST (new developer setup)
# 1. cp .env.example .env
# 2. php artisan key:generate
# 3. Configure DB_* above (SQLite needs no extra steps)
# 4. php artisan migrate --seed
# 5. php artisan storage:link
# 6. php artisan serve
# 7. (Optional) php artisan queue:work  for background jobs
##############################################################
