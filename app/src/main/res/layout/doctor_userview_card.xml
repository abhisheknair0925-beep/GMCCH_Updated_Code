<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp"
    android:elevation="5dp"
    android:layout_margin="10dp"
    app:cardBackgroundColor="?attr/colorSurface">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">


        <TextView
            android:id="@+id/duc_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="@string/name"
            android:textColor="?attr/colorOnSurface"
            android:layout_toRightOf="@id/duc_time"
            android:textSize="20sp"
            android:padding="5dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="20dp"
            android:layout_marginLeft="20dp"
            android:layout_alignParentLeft="true" />
        <TextView
            android:id="@+id/duc_age"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="O P Num"
            android:textSize="20sp"
            android:padding="5dp"
            android:textColor="?attr/colorOnSurface"

            android:layout_marginStart="20dp"
            android:layout_marginLeft="20dp"
           android:layout_below="@id/duc_name" />
        <TextView
            android:id="@+id/duc_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="Token No"
            android:textSize="20sp"
            android:padding="5dp"
            android:layout_alignParentLeft="true"
            android:textColor="?attr/colorOnSurface"
            android:layout_below="@id/duc_age"
            android:layout_marginStart="20dp"
            android:layout_marginLeft="20dp" />
        <Button
            android:id="@+id/duc_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View"
            android:textSize="15dp"
            android:layout_centerVertical="true"
            android:layout_alignParentRight="true"
            android:layout_marginRight="10dp"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>