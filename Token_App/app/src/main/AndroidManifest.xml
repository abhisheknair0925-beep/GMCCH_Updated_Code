<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <queries>
        <package android:name="com.google.android.gms" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@drawable/llogo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/llogo"
        android:supportsRtl="true"
        android:theme="@style/Theme.TokenNew"
        tools:ignore="GoogleAppIndexingWarning">

        <!-- Splash Screen (Main Launcher) -->
        <activity
            android:exported="true"
            android:name="gmcch.vast.token.SplashScreen"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- App Activities -->
        <activity android:name="gmcch.vast.token.About" android:label="@string/title_about" />
        <activity android:name="gmcch.vast.token.User.ViewCurentBooking" />
        <activity android:name="gmcch.vast.token.MainActivity" />

        <activity
            android:name="gmcch.vast.token.User.UserHomePage"
            android:parentActivityName="gmcch.vast.token.MainActivity"
            android:theme="@style/Theme.TokenNew" />
        <activity
            android:name="gmcch.vast.token.Doctor.DoctorHomePage"
            android:parentActivityName="gmcch.vast.token.MainActivity"
            android:theme="@style/Theme.TokenNew" />

        <activity android:name="gmcch.vast.token.User.UserLogin" />
        <activity
            android:name="gmcch.vast.token.Doctor.DoctorLogin"
            android:label="@string/title_activity_doctor_login" />

    </application>

</manifest>
